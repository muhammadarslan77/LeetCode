class Solution:
    def maximumSafenessFactor(self, grid: List[List[int]]) -> int:
        n = len(grid)
        q = deque()
        
        for i in range(n):
            for j in range(n):
                if grid[i][j]:
                    q.append( (i, j) )
        
        while q:
            for _ in range(len(q)):
                x, y = q.popleft()
                
                for i, j in [ (x, y + 1), (x, y - 1), (x + 1, y), (x - 1, y) ]:
                    if 0 <= i < n and 0 <= j < n and grid[i][j] == 0:
                        q.append( (i, j) )
                        grid[i][j] = grid[x][y] + 1
        
        q = [(-grid[0][0], 0, 0)]
        seen = set( [(0, 0)] )
        res = inf
        
        while q:
            for i in range(len(q)):
                w, x, y = heappop(q)
                res = min(res, -w)
                
                if x == y == n - 1:
                    return res - 1
                
                for i, j in [ (x, y + 1), (x, y - 1), (x + 1, y), (x - 1, y) ]:
                    if 0 <= i < n and 0 <= j < n and (i, j) not in seen:
                        heappush(q, (-grid[i][j], i, j))
                        seen.add( (i, j) )
